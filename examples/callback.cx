//! 30\n
include <stdio.h>

alias Fun = int(int, int)

struct Calc {
    static int sum(int x, int y) {
        return x + y;
    }
}

struct Other {
    static Fun getSum() {
        return &Calc.sum;
    }

    static int callSum(Fun func, int x, int y) {
        return func(x, y);
    }
}

int main() {
    Fun func = Other.getSum();
    printf("%d\n", Other.callSum(func, 10, 20));
    return 0;
}
