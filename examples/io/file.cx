//! src: The Cx Programming Language\n\n
import std.arena;
import std.io;

int main() {
    Arena arena = Arena.new(64);
    defer arena.free();

    char* filename = "./examples/io/file.txt";
    FILE* file = fopen(filename, "rb");
    
    fseek(file, 0, SEEK_END);
    u32 size = (u32)ftell(file);
    rewind(file);
    
    char* source = arena.alloc(size);
    fread(source, 1, size, file);
    fclose(file);

    printf("src: %s\n", source);

    return 0;
}
